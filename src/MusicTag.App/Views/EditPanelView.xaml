<UserControl x:Class="MusicTag.App.Views.EditPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:MusicTag.App.ViewModels"
             xmlns:conv="clr-namespace:MusicTag.App.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:EditPanelViewModel}"
             d:DesignWidth="340"
             IsEnabled="{Binding IsEnabled}"
             PreviewKeyDown="OnPreviewKeyDown">

    <!--
        Every ui:TextBox below defaults to UpdateSourceTrigger=LostFocus (the WPF default
        for TextBox.Text), matching the plan's "commit on focus-lost/Enter" design; Enter is
        handled in code-behind (OnPreviewKeyDown) since Enter alone doesn't move focus.
        Comment is a single line like every other field here (per user feedback — it used to
        be a taller, multi-line AcceptsReturn box, inconsistent with the rest of the panel and
        with the grid's own single-line Comment column).

        M5: each field's PlaceholderText is bound to that field's *Mixed companion property
        (a MixedValue<T> snapshot — see EditPanelViewModel) via MixedValuePlaceholderConverter,
        which resolves to "<keep>" only when the selection disagrees on that field and to
        nothing otherwise — so a single selection (or a unanimous multi-selection) looks
        exactly like it did before M5, and an untouched mixed field simply shows the hint
        instead of a real value (Text itself is null/blank whenever mixed, per
        EditPanelViewModel.RefreshFieldsFromSelection).

        M6: album art moved out of this panel entirely — AlbumArtControl is now a sibling of
        this view in MainWindow.xaml (bound to its own AlbumArtViewModel), stacked above it per
        plan section 5, rather than nested inside here as the M5 read-only stand-in had it.

        Per user feedback ("let the album art scroll with the rest of the side panel"): this
        view no longer owns its own ScrollViewer — MainWindow.xaml wraps AlbumArtControl and
        this view together in one shared ScrollViewer instead, so the two scroll as a unit.
    -->
    <UserControl.Resources>
        <conv:NullableIntToStringConverter x:Key="NullableIntConverter" />
        <conv:MixedValuePlaceholderConverter x:Key="MixedValuePlaceholderConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <StackPanel Margin="12">
            <!-- Filename is never editable from this panel (renaming is exclusively the
                 inline grid action from M4 — F2 or double-click a Filename cell) — this hint
                 only ever appears to explain why, and only while >1 file is selected, per
                 plan section 5: "Filename is excluded from this panel entirely when >1 file
                 is selected ... renaming stays exclusively an inline per-row grid action." -->
            <Border Visibility="{Binding IsMultiSelection, Converter={StaticResource BoolToVisibilityConverter}}"
                    Margin="0,0,0,12" Padding="8" CornerRadius="4"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                <TextBlock Text="Renaming isn't available for multiple files here — use F2 or double-click a Filename cell in the grid to rename one file at a time."
                           TextWrapping="Wrap" Opacity="0.8" FontSize="11" />
            </Border>

            <TextBlock Text="Title" Margin="0,0,0,2" />
            <ui:TextBox Text="{Binding Title, UpdateSourceTrigger=LostFocus}"
                        PlaceholderText="{Binding TitleMixed, Converter={StaticResource MixedValuePlaceholderConverter}}"
                        Margin="0,0,0,8" />

            <TextBlock Text="Artist" Margin="0,0,0,2" />
            <ui:TextBox Text="{Binding Artist, UpdateSourceTrigger=LostFocus}"
                        PlaceholderText="{Binding ArtistMixed, Converter={StaticResource MixedValuePlaceholderConverter}}"
                        Margin="0,0,0,8" />

            <TextBlock Text="Album" Margin="0,0,0,2" />
            <ui:TextBox Text="{Binding Album, UpdateSourceTrigger=LostFocus}"
                        PlaceholderText="{Binding AlbumMixed, Converter={StaticResource MixedValuePlaceholderConverter}}"
                        Margin="0,0,0,8" />

            <TextBlock Text="Album Artist" Margin="0,0,0,2" />
            <ui:TextBox Text="{Binding AlbumArtist, UpdateSourceTrigger=LostFocus}"
                        PlaceholderText="{Binding AlbumArtistMixed, Converter={StaticResource MixedValuePlaceholderConverter}}"
                        Margin="0,0,0,8" />

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Track #" Margin="0,0,0,2" />
                    <ui:TextBox Text="{Binding TrackNumber, Converter={StaticResource NullableIntConverter}, UpdateSourceTrigger=LostFocus}"
                                PlaceholderText="{Binding TrackNumberMixed, Converter={StaticResource MixedValuePlaceholderConverter}}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Disc #" Margin="0,0,0,2" />
                    <ui:TextBox Text="{Binding DiscNumber, Converter={StaticResource NullableIntConverter}, UpdateSourceTrigger=LostFocus}"
                                PlaceholderText="{Binding DiscNumberMixed, Converter={StaticResource MixedValuePlaceholderConverter}}" />
                </StackPanel>
            </Grid>

            <TextBlock Text="Year" Margin="0,0,0,2" />
            <ui:TextBox Text="{Binding Year, Converter={StaticResource NullableIntConverter}, UpdateSourceTrigger=LostFocus}"
                        PlaceholderText="{Binding YearMixed, Converter={StaticResource MixedValuePlaceholderConverter}}"
                        Margin="0,0,0,8" />

            <TextBlock Text="Genre" Margin="0,0,0,2" />
            <ui:TextBox Text="{Binding Genre, UpdateSourceTrigger=LostFocus}"
                        PlaceholderText="{Binding GenreMixed, Converter={StaticResource MixedValuePlaceholderConverter}}"
                        Margin="0,0,0,8" />

            <TextBlock Text="Composer" Margin="0,0,0,2" />
            <ui:TextBox Text="{Binding Composer, UpdateSourceTrigger=LostFocus}"
                        PlaceholderText="{Binding ComposerMixed, Converter={StaticResource MixedValuePlaceholderConverter}}"
                        Margin="0,0,0,8" />

            <TextBlock Text="Comment" Margin="0,0,0,2" />
            <ui:TextBox Text="{Binding Comment, UpdateSourceTrigger=LostFocus}"
                        PlaceholderText="{Binding CommentMixed, Converter={StaticResource MixedValuePlaceholderConverter}}"
                        Margin="0,0,0,8" />

            <!-- Read-only technical metadata (bitrate/sample rate/codec/channels/file size/tag
                 formats/last modified) — the original request's "read-only view of deeper
                 technical metadata", backed by AudioFile.ExtendedInfo. Only shown for a single
                 selected file (see EditPanelViewModel.IsExtendedInfoVisible doc comment for why
                 multi-selection hides it instead of inventing a mixed-value story for it).
                 FontSize=12 matches AlbumArtControl's own details text, per user feedback ("make
                 the text of both consistent and also slightly larger" — this was 11, that was
                 10, both now 12).
                 Per further user feedback ("get rid of 'Technical Info', make the data centered
                 ... put each field on a new line") and then ("get rid of the background box"):
                 no header line, no Border/background, one "Label: value" pair per line (built
                 in EditPanelViewModel.FormatExtendedInfo), just a plain centered TextBlock. -->
            <TextBlock Visibility="{Binding IsExtendedInfoVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                       Text="{Binding ExtendedInfoSummary}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       Margin="0,4,0,0" Opacity="0.8" FontSize="12" />
        </StackPanel>
</UserControl>
