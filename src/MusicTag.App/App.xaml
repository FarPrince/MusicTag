<Application x:Class="MusicTag.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- WPF-UI's Fluent control styles + theme brushes. The Theme="Dark" here is
                     only ever the initial placeholder value parsed at XAML-load time — App.OnStartup
                     immediately calls IThemeService.ApplyTheme(settings.Theme) before the main
                     window is shown (M8), which swaps this dictionary's actual theme for
                     whichever of System/Light/Dark is persisted. -->
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <!-- Must be merged in AFTER ui:ControlsDictionary above, in its own dictionary
                     file — see ButtonOverrides.xaml's own doc comment for why declaring this
                     Style inline here instead (a real bug hit and fixed) silently broke
                     BasedOn's self-reference to WPF-UI's own default Button style. -->
                <ResourceDictionary Source="Styles/ButtonOverrides.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
